# Auth key for client access (min 8 chars)
AUTH_KEY=your-auth-key-here

# Internal auth between router and proxies (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_AUTH_SECRET=

# PROXY_COUNT is managed automatically by freellmapi.
# Do not edit — it is overwritten on deployment and reconciliation.
# PROXY_COUNT=1
